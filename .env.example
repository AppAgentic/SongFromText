# =============================================================================
# SongFromText — environment variable template.
# Copy this file to `.env.local` for local dev. Never commit `.env.local`.
# Production values are injected via apphosting.yaml + Secret Manager.
# =============================================================================

# --- Firebase client (safe to expose in the browser) -------------------------
# Find these in Firebase Console → Project settings → General → Your apps.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Firebase Admin SDK (server-only, optional for local dev) -----------------
# App Hosting uses application default credentials automatically.
# For local dev outside emulators, service account credentials can be provided.
# FIREBASE_PRIVATE_KEY must be the full PEM with \n escaped as literal \n.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Whop billing (server-only) ----------------------------------------------
# API keys from whop.com dashboard. Plan IDs are created dynamically at checkout.
WHOP_API_KEY=
WHOP_WEBHOOK_SECRET=
WHOP_COMPANY_ID=
SONG_WEEKLY_PRICE_GBP=6.99

# --- Kie.ai Suno (server-only) -----------------------------------------------
# Music generation API. Used in custom mode to enforce verbatim lyrics.
KIE_API_KEY=

# --- Meta ads attribution -----------------------------------------------------
# Pixel ID is public. CAPI access token is server-only.
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_GRAPH_VERSION=v25.0
META_TEST_EVENT_CODE=
